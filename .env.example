# BCrew AI OS — Environment Variable Template
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ─── Core Auth ────────────────────────────────────────────────────────────────
# Required to start the server.
AIOS_SESSION_SECRET=replace-with-32-plus-char-random-string
ADMIN_TOKEN=replace-with-your-admin-token
AGENT_FEEDBACK_SECRET=replace-with-32-plus-char-random-string

# ─── Database ─────────────────────────────────────────────────────────────────
# Defaults: Unix socket at /tmp, database bcrew_ai_os, user = $USER
# Override only if your Postgres setup differs.
# BCREW_DB_HOST=/tmp
# BCREW_DB_NAME=bcrew_ai_os
# BCREW_DB_USER=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
# HOST=127.0.0.1

# ─── AI / LLM API Keys ────────────────────────────────────────────────────────
# Required for intelligence features (extraction, synthesis, routing).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ─── Integrations (add as needed) ────────────────────────────────────────────
# ClickUp
# CLICKUP_PERSONAL_TOKEN=

# Follow Up Boss CRM
# FUB_SYSTEM_KEY=
# FUB_SYSTEM_NAME=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_REQUIRED_CHANNELS=

# Missive
# MISSIVE_API_TOKEN=

# Google OAuth (login)
# AIOS_GOOGLE_CLIENT_ID=

# Supabase
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Browser automation (Browserbase)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# Agent feedback email
# AGENT_FEEDBACK_SECRET=
# AGENT_FEEDBACK_FROM_EMAIL=
# AGENT_FEEDBACK_FROM_NAME=
